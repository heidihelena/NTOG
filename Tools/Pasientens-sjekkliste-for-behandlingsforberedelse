<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pasientens sjekkliste for behandlingsforberedelse</title>
  <style>
    body { margin:0; font-family: Arial, Helvetica, sans-serif; background:#f6f8fb; color:#1f2937; }
    header { background:#2563eb; color:white; padding:30px; }
    main { max-width:900px; margin:auto; padding:20px; }
    .card { background:white; padding:20px; border-radius:12px; margin-bottom:15px; }
    .question { margin-top:15px; }
    button { margin:4px; padding:8px; cursor:pointer; }
    button.selected { background:#2563eb; color:white; }
  </style>
</head>
<body>

<header>
<h1>Pasientens sjekkliste for behandlingsforberedelse</h1>
</header>

<main>
<div class="card">
<p>
Dette verktøyet hjelper med å identifisere faktorer som kan påvirke forberedelse til behandling, toleranse og restitusjon.
</p>
</div>

<div id="questions" class="card"></div>

<div class="card">
<p>Poengsum: <span id="score">0</span> / 44</p>
</div>
</main>

<script>
const questions = [
 {id:1, text:"Hvor godt klarer du daglige aktiviteter på egen hånd?"},
 {id:2, text:"Hvor ofte har du nok energi i hverdagen?"},
 {id:3, text:"Hvor lett kan du bevege deg?"},
 {id:4, text:"Hvor godt er dine andre sykdommer under kontroll?"},
 {id:5, text:"Hvor trygg er du på at medisinene dine er gjennomgått?"},
 {id:6, text:"Hvor stabil har vekten din vært nylig?"},
 {id:7, text:"Hvor godt spiser du nå?"},
 {id:8, text:"Hvor godt forstår du behandlingsforløpet?"},
 {id:9, text:"Hvor godt håndterer du stress og bekymring?"},
 {id:10, text:"Hvor mye støtte får du i hverdagen?"},
 {id:11, text:"Hvor lett får du hjelp til praktiske oppgaver?"}
];

const answers = {};

function render(){
 const c=document.getElementById("questions");
 c.innerHTML="";
 questions.forEach(q=>{
   const d=document.createElement("div");
   d.className="question";
   d.innerHTML=`<p>${q.id}. ${q.text}</p>
   ${[0,1,2,3,4].map(s=>`<button onclick="select(${q.id},${s})">${s}</button>`).join("")}`;
   c.appendChild(d);
 });
}

function select(id,score){
 answers[id]=score;
 update();
}

function update(){
 const total=Object.values(answers).reduce((a,b)=>a+b,0);
 document.getElementById("score").textContent=total;
}

render();
</script>

</body>
</html>
